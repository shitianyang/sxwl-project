<?xml version="1.0" encoding="UTF-8"?>
<!-- Logback 配置文件 -->
<!-- 文档：https://logback.qos.ch/manual/configuration.html -->
<configuration>

    <!-- ==================== 属性定义 ==================== -->
    <!-- 应用名称，与 application.yaml 中 spring.application.name 一致 -->
    <property name="APP_NAME" value="sxwl-boot"/>
    <!-- 日志输出路径 -->
    <property name="LOG_PATH" value="./logs"/>
    <!-- 日志格式 -->
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n"/>
    <!-- 控制台彩色日志格式 -->
    <property name="CONSOLE_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) %magenta([%thread]) %cyan(%logger{50}) - %msg%n"/>

    <!-- ==================== 控制台输出（彩色） ==================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 文件输出 ==================== -->
    <!-- 全量日志 -->
    <appender name="FILE_ALL" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 日志文件路径 -->
        <file>${LOG_PATH}/${APP_NAME}.log</file>
        <!-- 滚动策略：按日期+大小分割 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 文件名格式：按天分割，同一天多个文件用索引区分 -->
            <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 单个文件最大 50MB -->
            <maxFileSize>50MB</maxFileSize>
            <!-- 保留 30 天 -->
            <maxHistory>30</maxHistory>
            <!-- 总大小上限 2GB -->
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 错误日志单独文件 -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}-error.log</file>
        <!-- 只记录 ERROR 级别 -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ==================== 开发环境配置 ==================== -->
    <springProfile name="dev">
        <!-- 项目代码：DEBUG -->
        <logger name="com.sxwl" level="DEBUG"/>
        <!-- MyBatis SQL 日志 -->
        <logger name="org.mybatis" level="DEBUG"/>
        <!-- Spring Web -->
        <logger name="org.springframework.web" level="INFO"/>
        <!-- HikariCP 连接池 -->
        <logger name="com.zaxxer.hikari" level="INFO"/>
        <!-- 根日志级别 -->
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ==================== 测试环境配置 ==================== -->
    <springProfile name="test">
        <!-- 项目代码：DEBUG -->
        <logger name="com.sxwl" level="DEBUG"/>
        <!-- MyBatis SQL 日志 -->
        <logger name="org.mybatis" level="DEBUG"/>
        <!-- Spring Web -->
        <logger name="org.springframework.web" level="INFO"/>
        <!-- HikariCP 连接池 -->
        <logger name="com.zaxxer.hikari" level="INFO"/>
        <!-- 根日志级别 -->
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ==================== 生产环境配置 ==================== -->
    <springProfile name="prod">
        <!-- 项目代码：INFO -->
        <logger name="com.sxwl" level="INFO"/>
        <!-- MyBatis -->
        <logger name="org.mybatis" level="WARN"/>
        <!-- Spring Web -->
        <logger name="org.springframework.web" level="WARN"/>
        <!-- HikariCP -->
        <logger name="com.zaxxer.hikari" level="WARN"/>
        <!-- 根日志级别 -->
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE_ALL"/>
            <appender-ref ref="FILE_ERROR"/>
        </root>
    </springProfile>

</configuration>
